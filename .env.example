# PalusOS public-safe operator template
# Copy to .env.local only in a private deployment. Do not commit real values.
# This repository does not implement live transaction signing or sending.

# Data adapters ---------------------------------------------------------------
# Public repo defaults to bundled demo rows. Private deployments can point an
# adapter at read-only market feeds, quote archives, or agent decision logs.
PALUS_DATA_ADAPTER_MODE=demo
PALUS_PRIVATE_MARKET_FEED_URL=
PALUS_PRIVATE_AGENT_LOG_PATH=

# RPC / wallet boundary -------------------------------------------------------
# Placeholder names only. Wallet/RPC are operator-provided in private infra.
# Never paste a private key into this file; use your own secret manager.
PALUS_RPC_URL=
PALUS_WALLET_REFERENCE=

# Canary gate -----------------------------------------------------------------
# Canary remains disabled by default. Enabling it requires private code,
# human approval, hard caps, quote freshness checks, and rollback triggers.
PALUS_CANARY_ENABLED=false
PALUS_CANARY_MAX_TRADE_SOL=0.005
PALUS_CANARY_MAX_DAILY_SOL=0.025
PALUS_CANARY_REQUIRE_HUMAN_APPROVAL=true
PALUS_CANARY_ROLLBACK_DRAWDOWN_SOL=0.01
PALUS_CANARY_ROLLBACK_ON_FAILED_EXIT=true
